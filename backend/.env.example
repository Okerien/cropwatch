# CropWatch backend environment — copy to .env and fill in.
# With NO NASA credentials set, the backend runs in DEMO mode automatically,
# serving synthetic-but-plausible NDVI so the whole app is usable immediately.

# --- NASA Earthdata (enables live MODIS via AppEEARS) ---
# Register free at https://urs.earthdata.nasa.gov (no credit card, instant).
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# --- Runtime ---
FLASK_ENV=development
# Force demo mode even when credentials exist (useful for offline dev):
# CROPWATCH_DEMO=true

# --- AI report keys (Phase 4 — not required for Phase 1) ---
GROQ_API_KEY=
GOOGLE_API_KEY=
HF_API_KEY=
